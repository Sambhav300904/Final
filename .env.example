# Copy to .env in this folder (AI Adoption V1) and fill in values.
# Do not commit .env — it contains secrets.

# --- Cursor sync ---
CURSOR_BASE_URL=https://api.cursor.com
CURSOR_API_KEY=

# --- GitHub Copilot sync (optional) ---
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_API_BASE=https://api.github.com

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=aiev

# --- Profile LLM (always multimodal Qwen-VL via Novita/HF — text + evidence images) ---
PROFILE_LLM_PROVIDER=multimodal
PROFILE_LLM_MODEL=Qwen/Qwen3-VL-8B-Instruct
PROFILE_LLM_TEMPERATURE=0.2
PROFILE_LLM_TIMEOUT_SEC=600
PROFILE_MAX_EVIDENCE_IMAGES=10
# HF_TOKEN / NOVITA_API_KEY used for profile when PROFILE_LLM_PROVIDER=multimodal

# --- Embeddings (local BGE — used for Pinecone scoring) ---
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# --- Pinecone ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=aiev-competencies-bge
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
TELEMETRY_MATCH_THRESHOLD=0.68

# --- Evidence summarizer (HF vision + text) ---
HF_TOKEN=
NOVITA_API_KEY=
EVIDENCE_LLM_PROVIDER=novita
EVIDENCE_LLM_MODEL=Qwen/Qwen3-VL-8B-Instruct
EVIDENCE_LLM_TIMEOUT_SEC=600

# --- Evidence validator (pre/post filter; images use Qwen3-VL vision first) ---
EVIDENCE_VALIDATOR_ENABLED=true
EVIDENCE_VALIDATOR_MIN_CONFIDENCE=0.5
EVIDENCE_VISION_SOURCE_OF_TRUTH=true
EVIDENCE_PREVALIDATE_MAX_CHARS=8000
